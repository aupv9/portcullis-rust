# UCI config for portcullis (/etc/config/portcullis) — TDD §9.
# Per-store values (store_id, control_endpoint, keys) are filled by the fleet
# provisioning pipeline / first-boot bootstrap (uci-defaults/99-portcullis).
#
# Hot-reloadable (applied live on SIGHUP): garden_fqdn, tier defaults,
#   accounting_interval, reap_conntrack, shape_*, idle_timeout.
# Requires restart: control_endpoint, cp_server_ca_file, cp_server_name,
#                   hmac_key_file, responder_port, firewall_backend.
#
# The control plane can also push tier policies / garden / enforcement toggle /
# engine params at runtime over the mTLS control stream (these override the
# static values below); it reads engine info + metrics for fleet drift.
#
# The engine DIALS control_endpoint outbound (the router is behind CGNAT), so
# no inbound port is exposed. It presents /etc/portcullis/tls/client.{crt,key}
# and verifies the control plane against cp_server_ca_file.

config portcullis 'main'
	option store_id            'SITE-0000'
	option control_endpoint    'https://cp.wifihub.internal:8443'
	option cp_server_ca_file   '/etc/portcullis/tls/cp-ca.crt'
	option cp_server_name      'cp.wifihub.internal'
	option hmac_key_file       '/etc/portcullis/hmac.key'
	option responder_port      '8080'
	option accounting_interval '15'
	option default_ttl         '1800'
	option default_quota_mb    '0'
	option default_rate_kbps   '2048'
	# Firewall backend: auto|nft|ipset (default auto). "auto" probes the kernel
	# for nftables NAT support and falls back to ipset+iptables — stock RutOS
	# (no CONFIG_NFT_NAT) lands on ipset (TDD §17 option B). Changing this
	# requires a restart (the backend is chosen once at composition).
	option firewall_backend    'auto'
	# Hotspot interface enforcement is scoped to (P0). The FORWARD/PREROUTING
	# gate is bound to `-i <hotspot_iface>` (iptables) / `iifname "<iface>"`
	# (nft) so ONLY the public SSID is gated — br-lan (admin) is never touched.
	# Empty (the default) = NOT scoped: the engine still creates its table/sets/
	# chains (kernel-as-truth adoption keeps working) but installs NO gate at all
	# (fail-OPEN — nothing is blocked). The control plane fills this with the
	# bridge the provision subsystem creates (e.g. 'br-hotspot'). Set it before
	# expecting the captive to gate anything.
	option hotspot_iface       ''
	# Conntrack reaping (invariant #9): sever a client's established flows on
	# de-auth (revoke/expiry/quota/idle) so removing it actually drops it, not
	# just its new connections. Default on; needs the `conntrack` binary.
	option reap_conntrack      '1'
	# Per-session bandwidth cap (tc/HTB). Off by default (device-validated). When
	# on, shape_iface must name the LAN egress bridge; the engine then advertises
	# the `shaper` capability so the control plane may push per-tier rate caps.
	option shape_bandwidth     '0'
	option shape_iface         'br-lan'
	# Idle-timeout seconds (0 = disabled). Local seed; the control plane can
	# override at runtime. A session with no traffic for this long is de-authed
	# with an IDLE_TIMEOUT event.
	option idle_timeout        '0'
	list   garden_fqdn         'portal.wifihub.vn'
	list   garden_fqdn         'cdn.wifihub.vn'
	list   garden_fqdn         'otp.gateway'
	list   garden_fqdn         'pay.example'
