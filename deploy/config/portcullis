# UCI config for portcullis (/etc/config/portcullis) — TDD §9.
# Per-store values (store_id, control_endpoint, keys) are filled by the fleet
# provisioning pipeline / first-boot bootstrap (uci-defaults/99-portcullis).
#
# Hot-reloadable: garden_fqdn, tier defaults, accounting_interval.
# Requires restart: control_endpoint, wg_interface, hmac_key_file, responder_port,
#                   redirect_rl_*, event_buffer_size, firewall_backend.

config portcullis 'main'
	option store_id            'SITE-0000'
	option control_endpoint    'https://cp.wifihub.internal:8443'
	option wg_interface        'wg-hub'
	option hmac_key_file       '/etc/portcullis/hmac.key'
	option responder_port      '8082'
	option accounting_interval '15'
	option default_ttl         '1800'
	option default_quota_mb    '0'
	option default_rate_kbps   '2048'
	# Global enforcement gate applied at boot (fail-closed default = '1').
	# Set '0' to boot with the gate OFF (all clients reach the internet, no
	# captive redirect) — useful for staging/maintenance. The control plane can
	# flip it live via the SetEnforcement gRPC without a restart.
	option enforcement_default '1'
	# Redirect responder rate limit (per source IP) + gRPC event buffer bound.
	# Optional — omitting them keeps these built-in values. RequiresRestart.
	option redirect_rl_capacity       '5'
	option redirect_rl_refill_per_sec '1'
	option redirect_rl_max_keys       '10000'
	# Replayable event-log depth (at-least-once StreamEvents window, ~100B/event).
	option event_buffer_size          '4096'
	# Per-client tc/HTB download shaper (§7.7). Opt-in: needs `tc` + HTB kmod on
	# the device; if the runtime probe fails the daemon logs and runs unshaped.
	option shaper_enabled             '0'
	option shape_interface            'br-lan'
	# Firewall backend: 'auto' (default) probes the kernel for nft NAT support
	# and falls back to ipset+iptables (the stock-RutOS path, no CONFIG_NFT_NAT);
	# 'nft' / 'ipset' force a backend. RequiresRestart.
	# option firewall_backend           'auto'
	list   garden_fqdn         'portal.wifihub.vn'
	list   garden_fqdn         'cdn.wifihub.vn'
	list   garden_fqdn         'otp.gateway'
	list   garden_fqdn         'pay.example'
